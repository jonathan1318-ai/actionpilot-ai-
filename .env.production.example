# Copy this to .env.production and fill in your values, then run `npm run build`.
# Never commit .env.production — it is in .gitignore.
#
# Same Firebase config as .env.local (these values are public, safe to reuse),
# but VITE_AI_PROXY_URL should point at your DEPLOYED Worker
# (from `cd worker && npm run deploy`), not localhost.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# e.g. https://actionpilot-ai-proxy.<your-subdomain>.workers.dev
VITE_AI_PROXY_URL=
